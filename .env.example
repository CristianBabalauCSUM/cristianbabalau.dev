# ---------------------------------------------------------------------------
# Environment variables. Copy to `.env.local` for local dev, and set the real
# values in Netlify (Site configuration → Environment variables).
# NEVER commit real keys — this file holds placeholders only.
# ---------------------------------------------------------------------------

# Contact form email delivery via Resend (https://resend.com).
# Without this, /api/contact validates + logs but does not send email.
RESEND_API_KEY=your_resend_api_key

# Optional overrides:
# Inbox that receives contact submissions (defaults to site.email).
# CONTACT_TO_EMAIL=you@example.com
# Sender address. onboarding@resend.dev works without domain verification;
# use a verified domain for a custom from-address.
# CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
